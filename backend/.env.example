ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=
TAVILY_API_KEY=your_tavily_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Multi-Model Support
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# ============================================================================
# FINANCIAL DATA APIs (NEW)
# ============================================================================

# Finnhub (Free: 60 requests/minute) ⭐ RECOMMENDED
# Get key: https://finnhub.io/register
FINNHUB_API_KEY=

# FRED - Federal Reserve Economic Data (Free: Unlimited) ⭐ RECOMMENDED
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Polygon.io (Free: 5 requests/minute, 15-min delayed)
# Get key: https://polygon.io/dashboard/signup
POLYGON_API_KEY=

# Twelve Data (Free: Limited daily credits)
# Get key: https://twelvedata.com/pricing
TWELVE_DATA_API_KEY=

# Financial Modeling Prep (Free tier available)
# Get key: https://site.financialmodelingprep.com/developer/docs/
FMP_API_KEY=

# ============================================================================
# NO API KEY NEEDED (Free APIs - Work Automatically)
# ============================================================================
# - CoinGecko (Cryptocurrency prices)
# - Frankfurter (Forex rates)

# ============================================================================
# REDIS & DATABASE
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
