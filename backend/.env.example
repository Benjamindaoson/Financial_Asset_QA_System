DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

TAVILY_API_KEY=
ALPHA_VANTAGE_API_KEY=

# News APIs
NEWSAPI_API_KEY=
FINNHUB_API_KEY=            # 推荐配置，国内用户必需（免费注册 finnhub.io）

# Other Financial Data APIs
FRED_API_KEY=
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
FMP_API_KEY=

# 国内网络设置：Yahoo Finance 在国内不可用，建议开启以下选项
DISABLE_YFINANCE=true       # 禁用 yfinance（国内无法访问 Yahoo Finance）

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

CACHE_WARM_ENABLED=false
CACHE_WARM_INTERVAL_SECONDS=1800
CACHE_WARM_LIMIT=5
CACHE_WARM_CONCURRENCY=2

LOG_LEVEL=INFO

# Prompts Configuration
PROMPTS_CONFIG_PATH=prompts.yaml

# Hybrid Routing Configuration
HYBRID_ROUTING_ENABLED=true
HYBRID_ROUTING_CONFIDENCE_THRESHOLD=0.8
HYBRID_ROUTING_FALLBACK_TO_RULE=true

# Compliance Checking Configuration
COMPLIANCE_RULE_CHECK_ENABLED=true
COMPLIANCE_LLM_CHECK_ENABLED=true
COMPLIANCE_STRICT_MODE=false

# LLM Timeout Configuration (seconds)
LLM_ROUTER_TIMEOUT=10
LLM_GENERATOR_TIMEOUT=30
LLM_COMPLIANCE_TIMEOUT=5
